     xmlns:skos="http://www.w3.org/2004/02/skos/core#">
    <owl:Ontology rdf:about="https://sostrades.eu.airbus.corp/ontology">
        <owl:versionIRI rdf:resource="https://sostrades.eu.airbus.corp/ontology/1.1.0"/>
        <dc:contributor rdf:datatype="http://www.w3.org/2000/01/rdf-schema#Literal">Etienne Tomiak</dc:contributor>
        <dc:contributor rdf:datatype="http://www.w3.org/2000/01/rdf-schema#Literal">Manel Ben Mna</dc:contributor>
        <dc:contributor rdf:datatype="http://www.w3.org/2000/01/rdf-schema#Literal">Stephane Biard</dc:contributor>
        <dc:description rdf:datatype="http://www.w3.org/2000/01/rdf-schema#Literal">This is the ontology used to represent all concepts used in the Systems of Systems Trades project. It is used to be a description of the concepts and relationship between them at any moment from the code information as well as a way to complement information with additional manually inputed info like label, definition, ...</dc:description>
        <owl:versionInfo rdf:datatype="http://www.w3.org/2000/01/rdf-schema#Literal">This evolution simplify the schema and add SoSDiscipline, SoSProcesses and links betweens all SoSConcepts</owl:versionInfo>
    </owl:Ontology>
    


